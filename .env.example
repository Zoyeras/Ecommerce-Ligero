# ============================================================
# 🔐 GOOGLE CLOUD SERVICE ACCOUNT CREDENTIALS
# ============================================================
# Obtén estos valores del archivo JSON descargado desde:
# Google Cloud Console > APIs y servicios > Credenciales

# ID del proyecto en Google Cloud
GOOGLE_PROJECT_ID=tu-proyecto-id-aqui

# ID de la clave privada
GOOGLE_PRIVATE_KEY_ID=tu-private-key-id-aqui

# Clave privada completa (incluir \n literalmente, SIN saltos de línea reales)
# Ejemplo correcto: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhk...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n\n-----END PRIVATE KEY-----\n"

# Email de la cuenta de servicio
GOOGLE_CLIENT_EMAIL=tu-correo-servicio@tu-proyecto.iam.gserviceaccount.com

# ID de cliente de Google
GOOGLE_CLIENT_ID=tu-client-id-aqui

# ============================================================
# 📁 GOOGLE DRIVE CONFIGURATION
# ============================================================
# ID de la carpeta raíz en Google Drive donde están tus productos
# Obtén el ID de la URL: https://drive.google.com/drive/folders/ID_AQUI
# Esta carpeta debe estar compartida con GOOGLE_CLIENT_EMAIL

DRIVE_FOLDER_ID=tu-carpeta-id-aqui
